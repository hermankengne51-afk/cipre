# Laisser vide : l'API (/api/*) vit dans la même app TanStack Start (même
# origine). Ne renseigner que si l'API est déployée séparément.
VITE_API_URL=

# Base de données (PostgreSQL)
DATABASE_URL="postgresql://username:password@host:port/database"

# Super administrateur — credentials reconnus directement par le système
# (une seule page de connexion, le système fait la différence en interne)
SUPER_ADMIN_EMAIL="superadmin@cipcre.org"
SUPER_ADMIN_PASSWORD="change-me-min-8-chars"

# Secret de chiffrement des cookies de session (min. 32 caractères)
# Générer avec : openssl rand -base64 32
AUTH_SECRET="un_code_tres_long_et_aleatoire_pour_chiffrer_les_cookies"

# Resend — envoi d'emails depuis l'admin (réponses aux messages et
# candidatures bénévoles). Laisser vide pour désactiver la fonctionnalité de
# réponse. Créez une clé API sur https://resend.com/api-keys
# Sans domaine vérifié sur Resend, utilisez RESEND_FROM="onboarding@resend.dev"
# (envoi limité à l'adresse du compte Resend). Avec un domaine vérifié
# (ex: cipcre.org), utilisez plutôt RESEND_FROM="CIPCRE <contact@cipcre.org>".
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="onboarding@resend.dev"
